{
  "services": {
    "web": {
      "root": "apps/web/"
    },
    "api": {
      "root": "services/api-vercel/",
      "entrypoint": "main.py",
      "routes": [
        {
          "src": "/api/(.*)",
          "transforms": [
            {
              "type": "request.path",
              "op": "set",
              "args": "/$1"
            }
          ]
        }
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/agent-runs",
      "destination": {
        "service": "web"
      }
    },
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "api"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ]
}
