{
  "name": "aegisops-agentic-portfolio",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "description": "Production-grade visual agentic workflow portfolio.",
  "pnpm": {
    "overrides": {
      "adm-zip": "0.6.0",
      "dompurify": "3.4.12",
      "postcss": "8.5.19"
    }
  },
  "scripts": {
    "dev:web": "pnpm --filter @aegisops/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "pnpm -r format",
    "test": "pnpm -r test",
    "docs:check": "node scripts/check-docs-placeholders.mjs",
    "vercel-api:sync-config": "node scripts/sync-vercel-api-config-snapshot.mjs",
    "vercel-api:check-config": "node scripts/sync-vercel-api-config-snapshot.mjs --check"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "promptfoo": "^0.121.18",
    "typescript": "^5.9.3"
  }
}
