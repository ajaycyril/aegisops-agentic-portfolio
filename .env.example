# Runtime
APP_ENV=local
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Public web gateway to the stateful full runtime. Leave disabled until the full runtime has
# managed Postgres, OPA, connector secrets, approvals, and spend controls configured.
FULL_RUNTIME_API_BASE_URL=
PUBLIC_LIVE_RUN_PROXY_ENABLED=false
FULL_RUNTIME_LIVE_RUN_ADMIN_KEY=
# Optional real stored run id for public trace/eval readouts. Do not use invented run ids.
DEMO_TRACE_RUN_ID=
DEMO_WORKFLOW_RUN_ID=
NEXT_PUBLIC_DEMO_WORKFLOW_RUN_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=
OPENAI_REASONING_MODEL=
OPENAI_EMBEDDING_MODEL=

# Database. For Supabase, use the managed Postgres connection string with the psycopg driver,
# pgvector enabled, and sslmode required by the provider.
# Example shape:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://aegisops:aegisops@localhost:5432/aegisops

# Redis / Upstash-compatible cache
REDIS_URL=redis://localhost:6379/0

# Policy
OPA_BASE_URL=http://localhost:8181

# Registries
CONFIGURED_CONNECTORS=
# Optional: override the default captured-real-run replay fixture directory.
# REPLAY_FIXTURE_DIR=/absolute/path/to/captured-real-replays

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OBSERVABILITY_CONNECTION_ID=
OBSERVABILITY_API_BASE_URL=
# Optional override for the default /logs/search read endpoint.
# OBSERVABILITY_LOG_SEARCH_PATH=/logs/search
OBSERVABILITY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Integrations
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
ACCOUNTING_SYSTEM_CONNECTION_ID=
CRM_CONNECTION_ID=
CRM_API_BASE_URL=
# Optional override for the default /customers/read endpoint.
# CRM_CUSTOMER_PROFILE_READ_PATH=/customers/read
CRM_API_KEY=
DEPLOYMENT_PLATFORM_CONNECTION_ID=
DEPLOYMENTS_CONNECTION_ID=
DEPLOYMENTS_API_BASE_URL=
# Optional override for the default /deployments/search read endpoint.
# DEPLOYMENTS_SEARCH_PATH=/deployments/search
DEPLOYMENTS_API_KEY=
DOCUMENT_STORE_CONNECTION_ID=
EMAIL_CONNECTION_ID=
IDENTITY_PROVIDER_CONNECTION_ID=
KNOWLEDGE_BASE_CONNECTION_ID=
KNOWLEDGE_BASE_API_BASE_URL=
# Optional override for the default /knowledge/search endpoint.
# KNOWLEDGE_BASE_SEARCH_PATH=/knowledge/search
KNOWLEDGE_BASE_API_KEY=
SUPPLIER_SYSTEM_CONNECTION_ID=
SUPPORT_SYSTEM_CONNECTION_ID=
SUPPORT_SYSTEM_API_BASE_URL=
# Optional override for the default /tickets/read endpoint.
# SUPPORT_TICKET_READ_PATH=/tickets/read
SUPPORT_SYSTEM_API_KEY=
TICKETING_CONNECTION_ID=

# Auth
AUTH_SECRET=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Safety and spend controls
MAX_AGENT_RUN_SECONDS=300
MAX_AGENT_TOOL_CALLS=25
MAX_AGENT_ESTIMATED_USD=1.00
REQUIRE_HUMAN_APPROVAL=true
LIVE_WORKFLOW_RUNS_ENABLED=false
LIVE_RUN_ADMIN_KEY=
